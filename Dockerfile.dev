# Dockerfile de desenvolvimento — sunOS Frontend (Next.js 14)
# Hot-reload via `next dev`; código montado por volume no compose.
FROM node:20-slim

ARG NODE_AUTH_TOKEN
ENV NODE_AUTH_TOKEN=${NODE_AUTH_TOKEN}

WORKDIR /app

# Instala dependências primeiro (camada cacheável)
COPY .npmrc package.json package-lock.json ./
RUN npm ci

EXPOSE 3003

# Código é montado por volume (ver docker-compose.yml); next dev observa mudanças
CMD ["npm", "run", "dev", "--", "-p", "3003", "-H", "0.0.0.0"]
