# infra/secrets.env.example
# Secrets to create in Google Secret Manager (infra/setup.sh creates the secret names).
# Never commit actual values. Use: echo -n 'VALUE' | gcloud secrets versions add NAME --data-file=-

# Cloud SQL — gerado pelo setup.sh
sunos-database-url=postgresql+asyncpg://sunos:PASSWORD@PRIVATE_IP/sunos

# Gemini API key (Google AI Studio ou Vertex AI)
sunos-google-api-key=AIza...

# Langfuse (ADR-013) — https://cloud.langfuse.com/settings
sunos-langfuse-secret-key=sk-lf-...
sunos-langfuse-public-key=pk-lf-...
