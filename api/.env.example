# sunOS API — Environment Variables

# Environment
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# Database (shared Cloud SQL)
DATABASE_URL=postgresql+asyncpg://sunos:sunos_dev_pass@localhost:5432/sunos_db

# LLM API Keys
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001

# Firebase
FIREBASE_PROJECT_ID=toolbox-67a0e

# GCP
GCP_PROJECT_ID=koro-creators
GCP_REGION=us-central1

# Google OAuth 2.0 — acesso por usuário ao Drive (SPEC-006 FA-14)
# Fonte: gcloud secrets versions access latest --secret=gws-oauth-client --project=koro-creators
# IMPORTANTE: registre o redirect URI em GCP Console → APIs & Services → Credentials → gws-oauth-client
#   Local dev:  http://localhost:8080/api/drive/callback
#   Cloud Run:  https://<service-url>/api/drive/callback
# ATENÇÃO prod: o cliente atual é tipo "installed". Para Cloud Run, converta para "Web application".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/drive/callback
GOOGLE_OAUTH_HD=
