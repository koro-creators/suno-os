# sunOS API — Environment Variables

# Environment
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# Database (shared Cloud SQL)
DATABASE_URL=postgresql+asyncpg://sunos:sunos_dev_pass@localhost:5432/sunos_db

# LLM API Keys
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001

# Firebase
FIREBASE_PROJECT_ID=toolbox-67a0e

# GCP
GCP_PROJECT_ID=koro-creators
GCP_REGION=us-central1
