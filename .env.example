# sunOS Frontend — Environment Variables

# Backend API URL (leave empty to use mock streaming)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Firebase (projeto koro-creators)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=koro-creators.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=koro-creators
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=koro-creators.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
